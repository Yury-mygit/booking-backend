SERVICE_NAME=booking-dev
VERSION=0.1.0
LOG_LEVEL=info

DATABASE_URL=postgresql+asyncpg://booking_dev:CHANGEME@db_shared:5432/booking_dev

TG_BOT_TOKEN_CLIENT=CHANGEME
TG_BOT_TOKEN_PARTNER=CHANGEME
TG_BOT_TOKEN_ADMIN=CHANGEME

# Set to true to enable /auth/dev-login bypass (dev only — NEVER in prod).
DEV_MODE=false

# Random secret that Telegram passes back as X-Telegram-Bot-Api-Secret-Token.
# Generate via `openssl rand -hex 24`. If empty — webhook accepts any caller (don't ship empty to prod).
TG_WEBHOOK_SECRET=
