SERVICE_NAME=booking-dev
VERSION=0.1.0
LOG_LEVEL=info

DATABASE_URL=postgresql+asyncpg://booking_dev:CHANGEME@db_shared:5432/booking_dev

# Один бот на все роли (client/partner/admin). После single-app rework
# (2026-05-25) множественные TG_BOT_TOKEN_* удалены — backend держит один токен.
TG_BOT_TOKEN=CHANGEME
TG_BOT_USERNAME=rforge_stay_bot

# Random secret, который Telegram передаёт обратно в X-Telegram-Bot-Api-Secret-Token.
# Generate: `openssl rand -hex 24`. Пустой = принимать любого, в prod не катит.
TG_WEBHOOK_SECRET=

# URL Mini App (inline-кнопка «Начать» в боте, deep-link'и). Single-app SPA.
PUBLIC_BASE_APP=https://book.dev.raftforge.art/

# /auth/dev-login bypass — только для локальной отладки. Никогда не в prod.
DEV_MODE=false

# initData freshness window (sec). Старше — отклоняем.
TG_INIT_DATA_MAX_AGE_SEC=3600

# Длина сессии (sec). 30 дней по умолчанию.
SESSION_TTL_SEC=2592000

# Storage для photo/QR uploads. /app/ — внутри контейнера (volume в compose).
STORAGE_PATH=/app/storage
PHOTO_MAX_BYTES=5242880
